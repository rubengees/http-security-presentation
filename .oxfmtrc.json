{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".idea", "dist"],
  "singleQuote": false,
  "printWidth": 120,
  "trailingComma": "all",
  "arrowParens": "always",
  "semi": false,
  "sortPackageJson": true,
  "sortTailwindcss": true,
  "sortImports": {
    "newlinesBetween": false
  }
}
